<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle if pageTitle else site.site_name }} — {{ site.site_description }}</title>
  <meta name="description" content="{{ pageDescription if pageDescription else site.site_description }}">
  <link rel="stylesheet" href="/assets/css/style.css">
  <!-- Google Consent Mode v2 — defaults BEFORE gtag loads -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent','default',{
      ad_storage:        'denied',
      ad_user_data:      'denied',
      ad_personalization:'denied',
      analytics_storage: 'denied',
      functionality_storage: 'denied',
      personalization_storage:'denied',
      security_storage:  'granted'
    });
  </script>
</head>
<body>

<a class="skip-link" href="#main-content">Skip to main content</a>

<nav class="nav" role="navigation" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="STZA home">
    <img src="/assets/images/stza-logo-white.svg"
         alt="STZA"
         style="height:40px;width:160px;object-fit:contain;object-position:left center;display:block;">
  </a>
  <ul class="nav-links" role="list">
    <li><a href="/#about">About</a></li>
    <li><a href="/#services">Services</a></li>
    <li><a href="/#approach">Approach</a></li>
    <li><a href="/#leadership">Leadership</a></li>
    <li><a href="/#contact" class="nav-cta">Get in touch</a></li>
  </ul>
  <button class="theme-toggle" aria-label="Toggle colour theme">◑ Auto</button>
  <button class="nav-hamburger" aria-label="Open navigation menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>
<div class="nav-mobile" role="navigation" aria-label="Mobile navigation">
  <a href="/#about">About</a>
  <a href="/#services">Services</a>
  <a href="/#approach">Approach</a>
  <a href="/#leadership">Leadership</a>
  <a href="/#contact" style="color:#C5A059;font-weight:700;">Get in touch →</a>
</div>

<main id="main-content">
  {{ content | safe }}
</main>

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-inner">
      <span style="font-size:18px;font-weight:800;color:#F0EEE9;letter-spacing:-0.3px;">ST<span style="color:#C5A059;">ZA</span><sup style="font-size:9px;">®</sup></span>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/#about">About</a>
        <a href="/#services">Services</a>
        <a href="/#contact">Contact</a>
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
        <a href="{{ site.africanstn_url }}" target="_blank" rel="noopener noreferrer">AfricanSTN</a>
      </nav>
    </div>
    <div class="footer-bottom">
      <p>© {{ site.copyright_year }} {{ site.entity_name }} · Companies House No. {{ site.companies_house }} · ICO No. {{ site.ico_number }} · United Kingdom</p>
      <p><a href="{{ site.africanstn_url }}" target="_blank" rel="noopener noreferrer">africanstn.com</a> &nbsp;·&nbsp; <a href="mailto:{{ site.email_hello }}">{{ site.email_hello }}</a></p>
    </div>
  </div>
</footer>

<!-- Cookie consent banner -->
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Cookie consent" aria-hidden="true">
  <div class="cookie-banner-inner">
    <p class="cookie-banner-text">We use cookies to improve your experience. Essential cookies keep the site running; optional cookies help with analytics and remember your preferences (like your theme choice). <a href="/privacy/#cookies">Learn more</a></p>
    <div class="cookie-banner-actions">
      <button id="cookie-accept" class="btn btn-primary cookie-btn">Accept all</button>
      <button id="cookie-essentials" class="btn btn-outline-gold cookie-btn">Essentials only</button>
    </div>
  </div>
</div>

<script src="/assets/js/script.js"></script>
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<script>
  if (window.netlifyIdentity) {
    window.netlifyIdentity.on("init", function(user) {
      if (!user) {
        window.netlifyIdentity.on("login", function() {
          document.location.href = "/admin/";
        });
      }
    });
  }
</script>
</body>
</html>
